[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = v3_req

[dn]
CN = JustSoSo Local Dev Server

[v3_req]
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
DNS.1 = localhost
IP.1 = 127.0.0.1
IP.2 = 192.168.0.120
IP.3 = 192.168.139.3
IP.4 = 192.168.97.0
IP.5 = 192.168.186.0
IP.6 = 192.168.183.0
IP.7 = 100.126.120.26
IP.8 = 192.168.207.0
